# CADIS does not require provider keys for local-only development.
# Add only the providers you use.

CADIS_HOME=~/.cadis
CADIS_LOG_LEVEL=info
CADIS_MODEL_PROVIDER=auto

# The desktop MVP reads Ollama settings from ~/.cadis/config.toml.
# [model]
# provider = "auto"
# ollama_model = "llama3.2"
# ollama_endpoint = "http://127.0.0.1:11434"

# OPENAI_API_KEY=
# Optional for the official Codex CLI. CADIS does not read this directly;
# `codex exec` consumes its own auth after `codex login` or CLI env setup.
# CODEX_API_KEY=
# CADIS_CODEX_BIN=codex
# CADIS_CODEX_MODEL=
# CADIS_CODEX_EXTRA_ARGS=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# TELEGRAM_BOT_TOKEN=
