#!/usr/bin/env node

const { execFileSync } = require("child_process");
const path = require("path");
const os = require("os");

const ext = os.platform() === "win32" ? ".exe" : "";
const bin = path.join(__dirname, "..", "native", `cadis${ext}`);

try {
  execFileSync(bin, process.argv.slice(2), { stdio: "inherit" });
} catch (e) {
  if (e.status != null) process.exit(e.status);
  console.error(`cadis: binary not found at ${bin}`);
  console.error("Run: npm rebuild @growthcircle/cadis");
  process.exit(1);
}
