{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CADIS HUD",
  "version": "0.1.0",
  "identifier": "ai.cadis.hud",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CADIS HUD",
        "width": 1600,
        "height": 1000,
        "minWidth": 1200,
        "minHeight": 760,
        "transparent": true,
        "decorations": false,
        "resizable": true,
        "shadow": true,
        "center": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "icon": ["icons/icon.png"]
  }
}
